{
  "name": "arch-drift",
  "version": "0.1.0",
  "description": "Prevent architecture drift. Define layer boundaries, detect violations, enforce on every commit.",
  "type": "module",
  "bin": {
    "arch-drift": "./dist/index.js"
  },
  "keywords": [
    "architecture",
    "architecture-drift",
    "enforce-boundaries",
    "module-boundaries",
    "code-boundaries",
    "linter",
    "cli",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omendivil/arch-drift.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/^#!.*\\n/,'#!/usr/bin/env node\\n'))\"",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "prepublishOnly": "bun test && bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
